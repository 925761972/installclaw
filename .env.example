# 火山引擎 AI MediaKit API Key（只放服务端，绝不能写入 NEXT_PUBLIC_ 变量）
VOLCENGINE_MEDIAKIT_API_KEY=

# Resend 邮件服务 API Key（用于邮箱验证码，注册 https://resend.com 获取）
RESEND_API_KEY=
# 发件人邮箱（需要在 Resend 后台验证域名，开发阶段可先用 Resend 提供的测试邮箱）
RESEND_FROM_EMAIL=

# 至少 32 位随机字符串，用于支付回调等服务端签名
APP_SECRET=replace-with-a-long-random-secret

# 数据库存储目录（留空则默认 ./data；Railway 挂持久卷可设为 /data）
DATA_DIR=

# 首发默认支付宝；后续可扩展 wechat
PAYMENT_PROVIDER=alipay

# 可选: alipay_web(电脑网站支付) / alipay_qr(扫码支付)
PAYMENT_METHOD=alipay_web

# 部署后的公网地址（用于火山引擎回调、支付回调、视频结果链接等）
PUBLIC_APP_URL=https://installclaw.cn

# 支付宝配置（首发）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://installclaw.cn/api/payments/alipay/notify
ALIPAY_RETURN_URL=https://installclaw.cn/pricing

# 微信支付预留（暂未启用）
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY=
WECHAT_CERT_SERIAL=
WECHAT_NOTIFY_URL=
